# Server
PORT=8787
HOST=0.0.0.0
NODE_ENV=development

# AI backend: mock | openai | openrouter | ollama | custom
AI_BACKEND=mock

# Transport: real | mock
ZALO_TRANSPORT=real

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Custom OpenAI-compatible endpoint
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=

# Prompt
OPENAI_SYSTEM_PROMPT=Bạn là trợ lý Zalo riêng của Quang. Trả lời bằng tiếng Việt, ngắn gọn, thân thiện, đúng trọng tâm.

# Zalo behavior
ZALO_GROUP_REQUIRE_MENTION=true
ZALO_FIRST_GREETING=Công Quang xin chào 👋
ZALO_INTRO_HINT=Bạn có thể đặt tên cho bot và chọn vibe như dễ thương, lịch sự, hài hước, lầy nhẹ, lạnh lùng hoặc chuyên nghiệp.

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_SESSION_SECRET=change-me-please

# Storage
ZALO_SESSION_PATH=./storage/zalo-session.json
ZALO_QR_PATH=./storage/zalo-qr.json
SETTINGS_PATH=./storage/settings.json
MESSAGES_JSON_PATH=./storage/messages.json
SQLITE_PATH=./storage/messages.sqlite

# Optional allowlists/blocklists (comma separated ids)
ZALO_DM_ALLOWLIST=
ZALO_DM_BLOCKLIST=
ZALO_GROUP_ALLOWLIST=
ZALO_GROUP_BLOCKLIST=
